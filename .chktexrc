# chktex configuration for TAOCP solutions
#
# Inline suppressions used in the project:
#   9  `)' expected, found ... — half-open intervals [a,b) and (a,b]
#  17  Number of ( doesn't match number of ) — cascades from chktex 9
#
# IMPORTANT: Run chktex from each file's directory (or use the provided script)
# so that \input{../../../template} resolves correctly with -I.
CmdLine
{
    -I
}
